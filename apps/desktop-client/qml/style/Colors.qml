pragma Singleton

import QtQuick

QtObject {
    // Backgrounds
    readonly property color background: "#1E1E1E"
    readonly property color surface: "#2B2B2B"
    readonly property color surfaceVariant: "#353535"

    // Borders
    readonly property color border: "#404040"

    // Primary / Accent
    readonly property color primary: "#1976D2"

    // Status
    readonly property color success: "#43A047"
    readonly property color warning: "#FB8C00"
    readonly property color error: "#E53935"

    // Text
    readonly property color textPrimary: "#F5F5F5"
    readonly property color textSecondary: "#B0B0B0"

}
